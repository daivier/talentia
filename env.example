# TalentAI — Variáveis de ambiente
# Renomeie este arquivo para ".env"

# ── API da Anthropic (IA) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-cole-sua-chave-aqui

# ── Servidor ──────────────────────────────────────────────
PORT=3000

# ── SMTP — Configuração de e-mail ─────────────────────────
# Servidor SMTP do seu provedor
SMTP_HOST=mail.suaempresa.com.br

# Porta: 587 (TLS) ou 465 (SSL)
SMTP_PORT=587

# true para porta 465, false para 587
SMTP_SECURE=false

# Credenciais
SMTP_USER=rh@suaempresa.com.br
SMTP_PASS=sua-senha-aqui
SMTP_FROM=rh@suaempresa.com.br

# ── Exemplos ──────────────────────────────────────────────
# cPanel/Hospedagem: SMTP_HOST=mail.suaempresa.com.br SMTP_PORT=587
# Gmail:             SMTP_HOST=smtp.gmail.com SMTP_PORT=587
# Outlook 365:       SMTP_HOST=smtp.office365.com SMTP_PORT=587
# Locaweb:           SMTP_HOST=email.locaweb.com.br SMTP_PORT=587
